<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2196F3"
    android:orientation="vertical">

    <!-- Стильная верхняя панель -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Mova"
            android:textColor="#2C3E50"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Иконка звука -->
        <ImageButton
            android:id="@+id/btnSoundSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Настройки звука"
            android:src="@drawable/ic_audio"
            android:tint="#2196F3"
            tools:ignore="UseAppTint" />

        <!-- Профиль (сдвигаем левее) -->
        <ImageButton
            android:id="@+id/btnProfile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentTop="true"
            android:layout_marginTop="11dp"
            android:layout_marginEnd="273dp"
            android:layout_toStartOf="@id/btnSoundSettings"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Профиль"
            android:src="@drawable/ic_person"
            android:tint="#2C3E50"
            tools:ignore="UseAppTint" />

    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

    <!-- Основной контент -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Приветствие -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Привет! 👋"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Что будем изучать сегодня?"
            android:textColor="#E3F2FD"
            android:textSize="16sp"
            android:layout_marginBottom="32dp" />

        <!-- Основные функции -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Словарь -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDictionary"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:background="?android:attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="44dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/ic_book"
                        android:tint="#2196F3"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:text="Словарь"
                        android:textColor="#2C3E50"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/ic_arrow_forward"
                        android:tint="#2C3E50"
                        tools:ignore="UseAppTint" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Тренировки -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTraining"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:background="?android:attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="46dp"
                        android:layout_height="54dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/ic_play_simple"
                        android:tint="#2196F3"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Тренировки"
                        android:textColor="#2C3E50"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="16dp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/ic_arrow_forward"
                        android:tint="#2C3E50"
                        tools:ignore="UseAppTint" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Грамматика -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardGrammar"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:background="?android:attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="42dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/ic_grammar"
                        android:tint="#2196F3"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Грамматика"
                        android:textColor="#2C3E50"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="16dp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_arrow_forward"
                        android:layout_gravity="center_vertical"
                        android:tint="#2C3E50"
                        tools:ignore="UseAppTint" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Статьи -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardArticles"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:background="?android:attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/ic_articles"
                        android:tint="#2196F3"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Статьи"
                        android:textColor="#2C3E50"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="16dp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_arrow_forward"
                        android:layout_gravity="center_vertical"
                        android:tint="#2C3E50"
                        tools:ignore="UseAppTint" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Прогресс внизу -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="23dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ваш прогресс"
                    android:textColor="#2C3E50"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Изучено 15 слов"
                        android:textColor="#666666"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15%"
                        android:textColor="#2196F3"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progress="15"
                    android:progressTint="#2196F3"
                    android:progressBackgroundTint="#E0E0E0"
                    style="@android:style/Widget.ProgressBar.Horizontal" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</LinearLayout>