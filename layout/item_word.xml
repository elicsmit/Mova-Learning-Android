<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#FFFFFF">

        <!-- Блок с картинкой -->
        <FrameLayout
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/image_background"
            android:padding="4dp">

            <ImageView
                android:id="@+id/wordImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_default_image"
                android:contentDescription="Изображение слова"
                android:background="#F8FAFC" />

            <!-- Статус изучения поверх картинки -->
            <ImageView
                android:id="@+id/ivStatus"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="top|end"
                android:src="@drawable/ic_learning"
                android:contentDescription="Статус изучения" />

        </FrameLayout>

        <!-- Блок с текстом -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp">

            <!-- Белорусское слово -->
            <TextView
                android:id="@+id/belarusianWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="дзякуй"
                android:textSize="18sp"
                android:textColor="#D22730"
                android:textStyle="bold" />

            <!-- Русский перевод -->
            <TextView
                android:id="@+id/russianWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="спасибо"
                android:textSize="16sp"
                android:textColor="#2D3748"
                android:layout_marginTop="4dp" />

            <!-- Английский перевод -->
            <TextView
                android:id="@+id/englishWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="thank you"
                android:textSize="14sp"
                android:textColor="#4A5568"
                android:layout_marginTop="2dp" />

            <!-- Пример использования -->
            <TextView
                android:id="@+id/tvExample"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Вялікі дзякуй за дапамогу!"
                android:textSize="12sp"
                android:textColor="#718096"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Прогресс-бар -->
            <LinearLayout
                android:id="@+id/progressLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:progress="60"
                    android:progressTint="#4299E1"
                    android:backgroundTint="#E2E8F0"
                    style="@android:style/Widget.ProgressBar.Horizontal" />

                <TextView
                    android:id="@+id/tvProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="60%"
                    android:textColor="#4299E1"
                    android:textSize="10sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- Кнопка меню -->
        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more_vert"
            android:contentDescription="Меню слова"
            android:layout_gravity="top" />

    </LinearLayout>

</androidx.cardview.widget.CardView>